{
  "name": "tuimux",
  "version": "0.5.4",
  "description": "A centralized TUI management app for running TUI applications in embedded terminal windows",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tuimux": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun run build.ts && echo '#!/usr/bin/env bun' | cat - dist/index.js > dist/temp && mv dist/temp dist/index.js && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shuv1337/tuimux.git"
  },
  "keywords": [
    "tui",
    "terminal",
    "cli",
    "multiplexer",
    "ghostty",
    "opentui"
  ],
  "author": "shuv1337",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shuv1337/tuimux/issues"
  },
  "homepage": "https://github.com/shuv1337/tuimux#readme",
  "dependencies": {
    "@opentui/core": "0.1.67",
    "@opentui/solid": "0.1.67",
    "fuse.js": "^7.0.0",
    "ghostty-opentui": "1.5.0",
    "solid-js": "1.9.9",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
